{
  "name": "claude-rpg",
  "version": "1.2.1",
  "description": "Simulation-grounded narrative RPG where worlds are generated live, but truth remains coherent",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "claude-rpg": "./dist/bin.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "tsc --build --clean",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "verify": "npm run build && npm run test"
  },
  "dependencies": {
    "@ai-rpg-engine/audio-director": "^2.0.0",
    "@ai-rpg-engine/campaign-memory": "^2.1.0",
    "@ai-rpg-engine/character-creation": "^2.0.0",
    "@ai-rpg-engine/character-profile": "^2.0.0",
    "@ai-rpg-engine/content-schema": "^2.0.0",
    "@ai-rpg-engine/core": "^2.0.0",
    "@ai-rpg-engine/equipment": "^2.0.0",
    "@ai-rpg-engine/modules": "^2.1.0",
    "@ai-rpg-engine/pack-registry": "^2.0.0",
    "@ai-rpg-engine/presentation": "^2.0.0",
    "@ai-rpg-engine/soundpack-core": "^2.0.0",
    "@ai-rpg-engine/starter-colony": "^2.0.0",
    "@ai-rpg-engine/starter-cyberpunk": "^2.0.0",
    "@ai-rpg-engine/starter-detective": "^2.0.0",
    "@ai-rpg-engine/starter-fantasy": "^2.0.0",
    "@ai-rpg-engine/starter-pirate": "^2.0.0",
    "@ai-rpg-engine/starter-weird-west": "^2.0.0",
    "@ai-rpg-engine/starter-zombie": "^2.0.0",
    "@ai-rpg-engine/terminal-ui": "^2.0.0",
    "@anthropic-ai/sdk": "^0.39.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "keywords": [
    "rpg",
    "claude",
    "ai",
    "narrative",
    "simulation",
    "worldbuilding",
    "text-rpg",
    "deterministic"
  ],
  "author": "mcp-tool-shop",
  "license": "MIT",
  "homepage": "https://github.com/mcp-tool-shop-org/claude-rpg",
  "repository": {
    "type": "git",
    "url": "https://github.com/mcp-tool-shop-org/claude-rpg.git"
  },
  "bugs": {
    "url": "https://github.com/mcp-tool-shop-org/claude-rpg/issues"
  },
  "engines": {
    "node": ">=20"
  }
}
